{
  "name": "termiboard",
  "version": "1.0.0",
  "description": "A real-time collaborative Kanban board.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev:server": "npm run dev -w termiboard-server",
    "dev:client-web": "npm run dev -w termiboard-client-web",
    "build:server": "npm run build -w termiboard-server",
    "build:client-web": "npm run build -w termiboard-client-web",
    "build:packages": "npm run build -w @termiboard/core",
    "start:server": "npm start -w termiboard-server"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SharifPoetra/termiboard.git"
  },
  "author": "SharifPoetra",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/SharifPoetra/termiboard/issues"
  },
  "homepage": "https://github.com/SharifPoetra/termiboard#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.4",
    "typescript": "^7.0.0",
    "typescript-eslint": "^8.61.0"
  }
}
