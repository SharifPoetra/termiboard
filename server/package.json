{
  "name": "@termiboard/server",
  "version": "1.0.0",
  "description": "A real-time collaborative Kanban board API built with Fastify, Drizzle ORM, PostgreSQL, and Socket.io.",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "start": "node .",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SharifPoetra/termiboard-backend.git"
  },
  "keywords": [
    "kanban",
    "board",
    "termiboard",
    "fastify",
    "backend"
  ],
  "author": "SharifPoetra",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/SharifPoetra/termiboard-backend/issues"
  },
  "homepage": "https://github.com/SharifPoetra/termiboard-backend#readme",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^7.0.0",
    "@fastify/jwt": "^10.1.0",
    "bcrypt": "^6.0.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "pg": "^8.21.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
